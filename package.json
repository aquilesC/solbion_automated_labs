{
  "name": "solbion-automated-labs",
  "version": "1.0.0",
  "description": "Solbion Static Website",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i themes/solbion/static/css/src/style.css -o themes/solbion/static/css/style.css",
    "watch:css": "tailwindcss -i themes/solbion/static/css/src/style.css -o themes/solbion/static/css/style.css --watch",
    "build": "npm run build:css && ./.venv/bin/pelican content",
    "dev": "concurrently \"npm run watch:css\" \"./.venv/bin/pelican -r -l -p 8123\""
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
